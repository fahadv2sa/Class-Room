model NoiseEvent {
  id                  String           @id @default(cuid())
  schoolId            String           @map("school_id")
  classroomId         String           @map("classroom_id")
  classroomDeviceId   String           @map("classroom_device_id")
  teacherId           String?          @map("teacher_id")
  attendanceSessionId String?          @map("attendance_session_id")
  startedAt           DateTime         @map("started_at")
  endedAt             DateTime?        @map("ended_at")
  durationSeconds     Int?             @map("duration_seconds")
  averageDb           Int              @map("average_db")
  peakDb              Int              @map("peak_db")
  sampleCount         Int              @default(1) @map("sample_count")
  severity            NoiseSeverity
  status              NoiseEventStatus @default(ACTIVE)
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  school              School           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom           Classroom        @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroomDevice     ClassroomDevice  @relation(fields: [classroomDeviceId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacher             Teacher?         @relation(fields: [teacherId, schoolId], references: [id, schoolId], onDelete: Restrict)
  attendanceSession   ClassroomAttendanceSession? @relation(fields: [attendanceSessionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  activeNoiseStates   ClassroomNoiseState[] @relation("ActiveNoiseEvent")

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([classroomDeviceId])
  @@index([teacherId])
  @@index([attendanceSessionId])
  @@index([status])
  @@index([severity])
  @@index([startedAt])
  @@map("noise_events")
}

model ClassroomNoiseSummary {
