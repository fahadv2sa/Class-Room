model SchoolSettings {
  id                      String   @id @default(cuid())
  schoolId                String   @unique @map("school_id")
  language                Language @default(AR)
  noiseThresholdDb        Int      @default(70) @map("noise_threshold_db")
  noiseDurationSeconds    Int      @default(10) @map("noise_duration_seconds")
  studentExitLimitMinutes Int      @default(10) @map("student_exit_limit_minutes")
  lateThresholdMinutes    Int      @default(10) @map("late_threshold_minutes")
  lateStudentThreshold    Int      @default(5) @map("late_student_threshold")
  movementThreshold       Int      @default(3) @map("movement_threshold")
  noiseEventThreshold     Int      @default(3) @map("noise_event_threshold")
  deviceOfflineThreshold  Int      @default(3) @map("device_offline_threshold")
  noiseAlertsEnabled      Boolean  @default(true) @map("noise_alerts_enabled")
  movementAlertsEnabled   Boolean  @default(true) @map("movement_alerts_enabled")
  attendanceAlertsEnabled Boolean  @default(true) @map("attendance_alerts_enabled")
  deviceAlertsEnabled     Boolean  @default(true) @map("device_alerts_enabled")
  dailyReportEnabled      Boolean  @default(false) @map("daily_report_enabled")
  schoolNameOverride      String?  @map("school_name_override")
  contactPhone            String?  @map("contact_phone")
  enabledAlertTypes       String[] @default(["STUDENT_LATE", "STUDENT_ABSENT", "EXCESSIVE_STUDENT_EXITS", "HIGH_NOISE_EVENT", "DEVICE_OFFLINE"]) @map("enabled_alert_types")
  enabledInsightTypes     String[] @default(["RECURRING_STUDENT_LATENESS", "EXCESSIVE_STUDENT_MOVEMENT", "CHRONIC_CLASSROOM_NOISE", "DEVICE_RELIABILITY_ISSUE"]) @map("enabled_insight_types")
  updatedAt               DateTime @updatedAt @map("updated_at")
  school                  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([language])
  @@map("school_settings")
}

