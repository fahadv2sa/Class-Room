generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SessionRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
}

enum SchoolStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SchoolLevelType {
  PRIMARY
  MIDDLE
  HIGH
}

enum Language {
  AR
  EN
}

enum Gender {
  MALE
  FEMALE
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
}

enum ClassroomDeviceStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum ConnectionStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum CardHolderType {
  STUDENT
  TEACHER
}

enum CardCredentialStatus {
  ACTIVE
  INACTIVE
  LOST
  REVOKED
}

enum RFIDActorType {
  STUDENT
  TEACHER
  UNKNOWN
}

enum RFIDScanDirection {
  ENTRY
  EXIT
  UNKNOWN
}

enum RFIDScanStatus {
  ACCEPTED
  DUPLICATE_IGNORED
  UNKNOWN_CARD
  INACTIVE_CARD
  WRONG_SCHOOL
  WRONG_CLASSROOM
  NO_ACTIVE_SESSION
}

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum StudentAttendanceStatus {
  ABSENT
  PRESENT
  LATE
  EXCUSED
}

enum StudentCurrentState {
  INSIDE_CLASSROOM
  OUTSIDE_CLASSROOM
  ABSENT
}

enum TeacherCurrentState {
  INSIDE_CLASSROOM
  OUTSIDE_CLASSROOM
}

enum MovementStatus {
  OPEN
  CLOSED
}

enum TeacherMovementStatus {
  INSIDE
  OUTSIDE
}

enum NoiseSeverity {
  LOW
  MEDIUM
  HIGH
}

enum NoiseEventStatus {
  ACTIVE
  CLOSED
}

enum NoiseState {
  QUIET
  MODERATE
  LOUD
}

enum SummaryPeriod {
  DAILY
  WEEKLY
  MONTHLY
  TERM
  YEARLY
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AlertType {
  STUDENT_LATE
  STUDENT_ABSENT
  EXCESSIVE_STUDENT_EXITS
  HIGH_NOISE_EVENT
  DEVICE_OFFLINE
}

enum AlertSourceType {
  ATTENDANCE
  MOVEMENT
  NOISE
  DEVICE
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

enum InsightType {
  RECURRING_STUDENT_LATENESS
  EXCESSIVE_STUDENT_MOVEMENT
  CHRONIC_CLASSROOM_NOISE
  DEVICE_RELIABILITY_ISSUE
}

enum ManagementSubjectType {
  SCHOOL
  LEVEL
  CLASSROOM
  TEACHER
  STUDENT
}

enum ManagementKpiType {
  ATTENDANCE_RATE
  LATE_RATE
  NOISE_SCORE
  MOVEMENT_SCORE
  TEACHER_PUNCTUALITY
  CLASSROOM_PERFORMANCE_SCORE
  STUDENT_ATTENTION_SCORE
}

model SuperAdmin {
  id                           String                      @id @default(cuid())
  email                        String                      @unique
  passwordHash                 String                      @map("password_hash")
  fullName                     String                      @map("full_name")
  isActive                     Boolean                     @default(true) @map("is_active")
  createdAt                    DateTime                    @default(now()) @map("created_at")
  updatedAt                    DateTime                    @updatedAt @map("updated_at")
  sessions                     Session[]
  approvedSchools              School[]                    @relation("SchoolApprovedBy")
  rejectedSchools              School[]                    @relation("SchoolRejectedBy")
  suspendedSchools             School[]                    @relation("SchoolSuspendedBy")
  approvedRegistrationRequests SchoolRegistrationRequest[] @relation("RegistrationApprovedBy")
  rejectedRegistrationRequests SchoolRegistrationRequest[] @relation("RegistrationRejectedBy")

  @@map("super_admins")
}

model School {
  id                 String             @id @default(cuid())
  schoolCode         String             @unique @map("school_code")
  name               String
  logoUrl            String?            @map("logo_url")
  city               String
  country            String
  subscriptionPlan   SubscriptionPlan   @default(STARTER) @map("subscription_plan")
  subscriptionStatus SubscriptionStatus @default(TRIALING) @map("subscription_status")
  status             SchoolStatus       @default(PENDING)
  approvedBy         String?            @map("approved_by")
  approvedAt         DateTime?          @map("approved_at")
  rejectedBy         String?            @map("rejected_by")
  rejectedAt         DateTime?          @map("rejected_at")
  suspendedBy        String?            @map("suspended_by")
  suspendedAt        DateTime?          @map("suspended_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  approvedByAdmin    SuperAdmin?        @relation("SchoolApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejectedByAdmin    SuperAdmin?        @relation("SchoolRejectedBy", fields: [rejectedBy], references: [id], onDelete: SetNull)
  suspendedByAdmin   SuperAdmin?        @relation("SchoolSuspendedBy", fields: [suspendedBy], references: [id], onDelete: SetNull)
  admins             SchoolAdmin[]
  subscriptions      Subscription[]
  sessions           Session[]
  academicYears      AcademicYear[]
  levels             SchoolLevel[]
  classrooms         Classroom[]
  settings           SchoolSettings?
  teachers           Teacher[]
  students           Student[]
  classroomDevices   ClassroomDevice[]
  cardCredentials    CardCredential[]
  rfidScanEvents     RFIDScanEvent[]
  attendanceSessions ClassroomAttendanceSession[]
  attendanceRecords  StudentAttendanceRecord[]
  studentPresenceStates StudentPresenceState[]
  teacherPresenceStates TeacherPresenceState[]
  studentMovementRecords StudentMovementRecord[]
  teacherMovementRecords TeacherMovementRecord[]
  noiseEvents       NoiseEvent[]
  classroomNoiseSummaries ClassroomNoiseSummary[]
  teacherNoiseSummaries TeacherNoiseSummary[]
  classroomNoiseStates ClassroomNoiseState[]
  alerts            Alert[]
  insights          Insight[]
  managementKpiSnapshots ManagementKpiSnapshot[]

  @@index([status])
  @@index([subscriptionStatus])
  @@map("schools")
}

model SchoolAdmin {
  id           String    @id @default(cuid())
  schoolId     String    @map("school_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  sessions     Session[]

  @@index([schoolId])
  @@index([isActive])
  @@map("school_admins")
}

model AcademicYear {
  id         String        @id @default(cuid())
  schoolId   String        @map("school_id")
  name       String
  startDate  DateTime      @map("start_date")
  endDate    DateTime      @map("end_date")
  isActive   Boolean       @default(false) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  school     School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  levels     SchoolLevel[]
  classrooms Classroom[]
  attendanceSessions ClassroomAttendanceSession[]

  @@unique([schoolId, name])
  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([schoolId, isActive])
  @@map("academic_years")
}

model SchoolLevel {
  id             String          @id @default(cuid())
  schoolId       String          @map("school_id")
  academicYearId String          @map("academic_year_id")
  levelType      SchoolLevelType @map("level_type")
  displayName    String          @map("display_name")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classrooms     Classroom[]

  @@unique([schoolId, academicYearId, levelType])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([schoolId, isActive])
  @@map("school_levels")
}

model Classroom {
  id             String       @id @default(cuid())
  schoolId       String       @map("school_id")
  academicYearId String       @map("academic_year_id")
  levelId        String       @map("level_id")
  classroomCode  String       @map("classroom_code")
  classroomName  String       @map("classroom_name")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  level          SchoolLevel  @relation(fields: [levelId], references: [id], onDelete: Restrict)
  students       Student[]
  classroomDevices ClassroomDevice[]
  rfidScanEvents RFIDScanEvent[]
  attendanceSessions ClassroomAttendanceSession[]
  attendanceRecords StudentAttendanceRecord[]
  studentPresenceStates StudentPresenceState[]
  teacherPresenceStates TeacherPresenceState[]
  studentMovementRecords StudentMovementRecord[]
  teacherMovementRecords TeacherMovementRecord[]
  noiseEvents      NoiseEvent[]
  noiseSummaries   ClassroomNoiseSummary[]
  noiseStates      ClassroomNoiseState[]
  alerts           Alert[]
  insights         Insight[]

  @@unique([schoolId, academicYearId, classroomCode])
  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([levelId])
  @@index([schoolId, isActive])
  @@map("classrooms")
}

model ClassroomDevice {
  id                    String                @id @default(cuid())
  schoolId              String                @map("school_id")
  classroomId           String                @map("classroom_id")
  deviceCode            String                @unique @map("device_code")
  serialNumber          String                @unique @map("serial_number")
  firmwareVersion       String                @map("firmware_version")
  hardwareVersion       String                @map("hardware_version")
  status                ClassroomDeviceStatus @default(ACTIVE)
  connectionStatus      ConnectionStatus      @default(UNKNOWN) @map("connection_status")
  capabilities          String[]              @default([])
  installedAt           DateTime              @map("installed_at")
  registeredAt          DateTime              @default(now()) @map("registered_at")
  lastSeenAt            DateTime?             @map("last_seen_at")
  retiredAt             DateTime?             @map("retired_at")
  notes                 String?
  provisionedAt         DateTime?             @map("provisioned_at")
  provisionedBy         String?               @map("provisioned_by")
  pairingTokenHash      String?               @map("pairing_token_hash")
  pairingTokenExpiresAt DateTime?             @map("pairing_token_expires_at")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  school                School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom             Classroom             @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  rfidScanEvents        RFIDScanEvent[]
  attendanceSessions    ClassroomAttendanceSession[]
  noiseEvents           NoiseEvent[]
  noiseStates           ClassroomNoiseState[]
  alerts                Alert[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([schoolId, status])
  @@index([schoolId, connectionStatus])
  @@map("classroom_devices")
}

model Teacher {
  id              String        @id @default(cuid())
  schoolId        String        @map("school_id")
  employeeNumber  String        @map("employee_number")
  fullNameAr      String        @map("full_name_ar")
  fullNameEn      String        @map("full_name_en")
  nationalId      String?       @map("national_id")
  email           String?
  phone           String?
  gender          Gender
  status          TeacherStatus @default(ACTIVE)
  hireDate        DateTime?     @map("hire_date")
  profilePhotoUrl String?       @map("profile_photo_url")
  cardCode        String        @unique @map("card_code")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  cardCredentials CardCredential[]
  rfidScanEvents  RFIDScanEvent[]
  attendanceSessions ClassroomAttendanceSession[]
  teacherPresenceStates TeacherPresenceState[]
  teacherMovementRecords TeacherMovementRecord[]
  noiseEvents      NoiseEvent[]
  noiseSummaries   TeacherNoiseSummary[]
  alerts           Alert[]
  insights         Insight[]

  @@unique([schoolId, employeeNumber])
  @@unique([id, schoolId])
  @@unique([schoolId, nationalId])
  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([fullNameAr])
  @@index([fullNameEn])
  @@map("teachers")
}

model Student {
  id              String        @id @default(cuid())
  schoolId        String        @map("school_id")
  classroomId     String        @map("classroom_id")
  studentNumber   String        @map("student_number")
  fullNameAr      String        @map("full_name_ar")
  fullNameEn      String        @map("full_name_en")
  nationalId      String?       @map("national_id")
  gender          Gender
  birthDate       DateTime?     @map("birth_date")
  guardianName    String?       @map("guardian_name")
  guardianPhone   String?       @map("guardian_phone")
  guardianEmail   String?       @map("guardian_email")
  profilePhotoUrl String?       @map("profile_photo_url")
  cardCode        String        @unique @map("card_code")
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom       Classroom     @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  cardCredentials CardCredential[]
  rfidScanEvents  RFIDScanEvent[]
  attendanceRecords StudentAttendanceRecord[]
  presenceStates StudentPresenceState[]
  movementRecords StudentMovementRecord[]
  alerts          Alert[]
  insights        Insight[]

  @@unique([schoolId, studentNumber])
  @@unique([id, schoolId])
  @@unique([schoolId, nationalId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([schoolId, status])
  @@index([schoolId, classroomId])
  @@index([fullNameAr])
  @@index([fullNameEn])
  @@map("students")
}

model CardCredential {
  id            String                 @id @default(cuid())
  schoolId      String                 @map("school_id")
  cardCode      String                 @unique @map("card_code")
  holderType    CardHolderType         @map("holder_type")
  studentId     String?                @map("student_id")
  teacherId     String?                @map("teacher_id")
  status        CardCredentialStatus   @default(ACTIVE)
  issuedAt      DateTime               @default(now()) @map("issued_at")
  deactivatedAt DateTime?              @map("deactivated_at")
  notes         String?
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  school        School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student       Student?               @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacher       Teacher?               @relation(fields: [teacherId, schoolId], references: [id, schoolId], onDelete: Restrict)
  scanEvents    RFIDScanEvent[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([studentId])
  @@index([teacherId])
  @@map("card_credentials")
}

model RFIDScanEvent {
  id                   String            @id @default(cuid())
  schoolId             String            @map("school_id")
  classroomDeviceId    String            @map("classroom_device_id")
  classroomId          String            @map("classroom_id")
  cardCredentialId     String?           @map("card_credential_id")
  cardCode             String            @map("card_code")
  actorType            RFIDActorType      @default(UNKNOWN) @map("actor_type")
  studentId            String?           @map("student_id")
  teacherId            String?           @map("teacher_id")
  scanDirection        RFIDScanDirection  @default(UNKNOWN) @map("scan_direction")
  scanStatus           RFIDScanStatus     @map("scan_status")
  scannedAt            DateTime           @map("scanned_at")
  receivedAt           DateTime           @default(now()) @map("received_at")
  sourceEventId        String?            @map("source_event_id")
  duplicateOfEventId   String?            @map("duplicate_of_event_id")
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  school               School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroomDevice      ClassroomDevice    @relation(fields: [classroomDeviceId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom            Classroom          @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  cardCredential       CardCredential?    @relation(fields: [cardCredentialId], references: [id], onDelete: SetNull)
  student              Student?           @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacher              Teacher?           @relation(fields: [teacherId, schoolId], references: [id, schoolId], onDelete: Restrict)
  duplicateOfEvent     RFIDScanEvent?     @relation("RFIDScanEventDuplicates", fields: [duplicateOfEventId], references: [id], onDelete: SetNull)
  duplicateEvents      RFIDScanEvent[]    @relation("RFIDScanEventDuplicates")
  studentPresenceStates StudentPresenceState[]
  teacherPresenceStates TeacherPresenceState[]
  studentMovementExits StudentMovementRecord[] @relation("StudentMovementExitScan")
  studentMovementReturns StudentMovementRecord[] @relation("StudentMovementReturnScan")
  teacherMovementEntries TeacherMovementRecord[] @relation("TeacherMovementEntryScan")
  teacherMovementExits TeacherMovementRecord[] @relation("TeacherMovementExitScan")

  @@index([schoolId])
  @@index([classroomDeviceId])
  @@index([classroomId])
  @@index([cardCode])
  @@index([scanStatus])
  @@index([scannedAt])
  @@index([sourceEventId])
  @@map("rfid_scan_events")
}

model ClassroomAttendanceSession {
  id                String                  @id @default(cuid())
  schoolId          String                  @map("school_id")
  academicYearId    String                  @map("academic_year_id")
  classroomId       String                  @map("classroom_id")
  classroomDeviceId String                  @map("classroom_device_id")
  teacherId         String?                 @map("teacher_id")
  sessionDate       DateTime                @map("session_date") @db.Date
  status            AttendanceSessionStatus @default(OPEN)
  openedAt          DateTime                @default(now()) @map("opened_at")
  closedAt          DateTime?               @map("closed_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  school            School                  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear      AcademicYear            @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom         Classroom               @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroomDevice   ClassroomDevice         @relation(fields: [classroomDeviceId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacher           Teacher?                @relation(fields: [teacherId, schoolId], references: [id, schoolId], onDelete: Restrict)
  records           StudentAttendanceRecord[]
  studentPresenceStates StudentPresenceState[]
  studentMovementRecords StudentMovementRecord[]
  noiseEvents       NoiseEvent[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([classroomId])
  @@index([classroomDeviceId])
  @@index([schoolId, status])
  @@index([sessionDate])
  @@map("classroom_attendance_sessions")
}

model StudentAttendanceRecord {
  id                  String                  @id @default(cuid())
  schoolId            String                  @map("school_id")
  attendanceSessionId String                  @map("attendance_session_id")
  classroomId         String                  @map("classroom_id")
  studentId           String                  @map("student_id")
  status              StudentAttendanceStatus @default(ABSENT)
  firstEntryAt        DateTime?               @map("first_entry_at")
  lastExitAt          DateTime?               @map("last_exit_at")
  scanCount           Int                     @default(0) @map("scan_count")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  school              School                  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  attendanceSession   ClassroomAttendanceSession @relation(fields: [attendanceSessionId, schoolId], references: [id, schoolId], onDelete: Cascade)
  classroom           Classroom               @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  student             Student                 @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([attendanceSessionId, studentId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([studentId])
  @@index([schoolId, status])
  @@map("student_attendance_records")
}

model StudentPresenceState {
  id                  String              @id @default(cuid())
  schoolId            String              @map("school_id")
  classroomId         String              @map("classroom_id")
  studentId           String              @map("student_id")
  attendanceSessionId String              @map("attendance_session_id")
  currentState        StudentCurrentState @default(ABSENT) @map("current_state")
  enteredAt           DateTime?           @map("entered_at")
  exitedAt            DateTime?           @map("exited_at")
  totalExits          Int                 @default(0) @map("total_exits")
  lastScanEventId     String              @map("last_scan_event_id")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  school              School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom           Classroom           @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  student             Student             @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  attendanceSession   ClassroomAttendanceSession @relation(fields: [attendanceSessionId, schoolId], references: [id, schoolId], onDelete: Cascade)
  lastScanEvent       RFIDScanEvent        @relation(fields: [lastScanEventId], references: [id], onDelete: Restrict)

  @@unique([attendanceSessionId, studentId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([studentId])
  @@index([schoolId, currentState])
  @@map("student_presence_states")
}

model TeacherPresenceState {
  id              String              @id @default(cuid())
  schoolId        String              @map("school_id")
  classroomId     String              @map("classroom_id")
  teacherId       String              @map("teacher_id")
  currentState    TeacherCurrentState @default(OUTSIDE_CLASSROOM) @map("current_state")
  enteredAt       DateTime?           @map("entered_at")
  exitedAt        DateTime?           @map("exited_at")
  lastScanEventId String              @map("last_scan_event_id")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom       Classroom           @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacher         Teacher             @relation(fields: [teacherId, schoolId], references: [id, schoolId], onDelete: Restrict)
  lastScanEvent   RFIDScanEvent        @relation(fields: [lastScanEventId], references: [id], onDelete: Restrict)

  @@unique([classroomId, teacherId])
  @@index([schoolId])
  @@index([classroomId])
  @@index([teacherId])
  @@index([schoolId, currentState])
  @@map("teacher_presence_states")
}

model StudentMovementRecord {
  id                  String         @id @default(cuid())
  schoolId            String         @map("school_id")
  classroomId         String         @map("classroom_id")
  studentId           String         @map("student_id")
  attendanceSessionId String         @map("attendance_session_id")
  exitScanEventId     String         @map("exit_scan_event_id")
  returnScanEventId   String?        @map("return_scan_event_id")
  exitedAt            DateTime       @map("exited_at")
  returnedAt          DateTime?      @map("returned_at")
  durationMinutes     Int?           @map("duration_minutes")
  status              MovementStatus @default(OPEN)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  school              School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classroom           Classroom      @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  student             Student        @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  attendanceSession   ClassroomAttendanceSession @relation(fields: [attendanceSessionId, schoolId], references: [id, schoolId], onDelete: Cascade)
  exitScanEvent       RFIDScanEvent  @relation("StudentMovementExitScan", fields: [exitScanEventId], references: [id], onDelete: Restrict)
  returnScanEvent     RFIDScanEvent? @relation("StudentMovementReturnScan", fields: [returnScanEventId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([classroomId])
  @@index([studentId])
  @@index([attendanceSessionId])
  @@index([schoolId, status])
  @@map("student_movement_records")
}

model TeacherMovementRecord {
